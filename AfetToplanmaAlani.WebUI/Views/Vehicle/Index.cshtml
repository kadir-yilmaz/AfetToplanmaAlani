@model X.PagedList.IPagedList<AfetToplanmaAlani.EL.Models.Vehicle>

@{
    ViewData["Title"] = "Araç Listesi";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1><i class="bi bi-truck me-2"></i>Araç Yönetimi</h1>
            <p>Araç bilgilerini görüntüle ve yönet</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="VehicleStaff" asp-action="Index" class="btn-header-add" style="background: rgba(255,255,255,0.1);">
                <i class="bi bi-people me-2"></i>Araç Personelleri
            </a>
            <a asp-action="Create" class="btn-header-add">
                <i class="bi bi-plus-circle me-2"></i>Araç Ekle
            </a>
        </div>
    </div>

    <!-- Search -->
    <div class="filter-card mb-4">
        <div class="card-body">
            <div class="row justify-content-center">
                <div class="col-md-6 col-lg-4">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" id="plateSearch" class="form-control" placeholder="Plaka numarası ile ara..." />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null || ViewBag.ErrorMessage != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @TempData["ErrorMessage"] ?? @ViewBag.ErrorMessage
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Vehicles Grid -->
    <div class="row g-4" id="vehiclesContainer">
        @if (Model != null && Model.Any())
        {
            foreach (var vehicle in Model)
            {
                <div class="col-md-6 col-lg-4 vehicle-item" data-plate="@vehicle.Plate?.ToLower()">
                    <div class="vehicle-card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center" style="background: var(--bg-muted); border-bottom: 1px solid var(--border-color);">
                            <span class="plate-badge">
                                <i class="bi bi-credit-card-2-front me-1"></i>
                                @vehicle.Plate
                            </span>
                            <div class="d-flex gap-2">
                                <a asp-action="Update" asp-route-id="@vehicle.Id" class="btn-action btn-action-edit" title="Düzenle">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@vehicle.Id" method="post" class="d-inline delete-form">
                                    <button type="submit" class="btn-action btn-action-delete" title="Sil">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <div class="card-body p-3">
                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <div class="text-muted small text-uppercase fw-semibold">Marka</div>
                                    <div class="fw-medium">@(vehicle.Brand ?? "Belirtilmemiş")</div>
                                </div>
                                <div class="col-6">
                                    <div class="text-muted small text-uppercase fw-semibold">Model</div>
                                    <div class="fw-medium">@(vehicle.Model ?? "Belirtilmemiş")</div>
                                </div>
                                <div class="col-6">
                                    <div class="text-muted small text-uppercase fw-semibold">Tip</div>
                                    <div class="fw-medium">@(vehicle.Type ?? "Belirtilmemiş")</div>
                                </div>
                                <div class="col-6">
                                    <div class="text-muted small text-uppercase fw-semibold">Renk</div>
                                    <div class="fw-medium">@(vehicle.Color ?? "Belirtilmemiş")</div>
                                </div>
                            </div>

                            <div class="pt-3 border-top">
                                <button type="button"
                                        class="btn btn-primary w-100"
                                        style="background: var(--primary-gradient); border: none;"
                                        data-bs-toggle="modal"
                                        data-bs-target="#staffModal"
                                        data-plate="@vehicle.Plate"
                                        data-staff='@System.Text.Json.JsonSerializer.Serialize(vehicle.VehicleStaff.Select(s => new { s.Name, s.Surname, s.PhoneNumber }))'>
                                    <i class="bi bi-people-fill me-1"></i>
                                    <span>Personelleri Göster (@(vehicle.VehicleStaff?.Count ?? 0))</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="table-card">
                    <div class="empty-state">
                        <i class="bi bi-truck"></i>
                        <h5>Henüz araç eklenmemiş</h5>
                        <p class="text-muted">İlk aracınızı eklemek için yukarıdaki "Araç Ekle" butonunu kullanın.</p>
                    </div>
                </div>
            </div>
        }
    </div>
    
    <!-- Pagination -->
    @if (Model != null && Model.Any())
    {
        <div class="mt-4">
            @await Html.PartialAsync("_Pagination", Model)
        </div>
    }
</div>

<!-- Staff Modal -->
<div class="modal fade" id="staffModal" tabindex="-1" aria-labelledby="staffModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background: var(--primary-gradient); color: white;">
                <h5 class="modal-title" id="staffModalLabel">Personel Listesi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="staffModalBody">
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Search functionality
        const searchInput = document.getElementById('plateSearch');
        const vehicleItems = document.querySelectorAll('.vehicle-item');

        searchInput.addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase().trim();

            vehicleItems.forEach(item => {
                const plateData = item.getAttribute('data-plate');

                if (plateData && plateData.includes(searchTerm)) {
                    item.style.display = '';
                } else {
                    item.style.display = 'none';
                }
            });

            // Show empty message if no results
            const visibleItems = document.querySelectorAll('.vehicle-item:not([style*="display: none"])');

            if (visibleItems.length === 0 && searchTerm !== '') {
                if (!document.querySelector('.no-results')) {
                    const noResults = document.createElement('div');
                    noResults.className = 'col-12 no-results';
                    noResults.innerHTML = `
                        <div class="table-card">
                            <div class="empty-state">
                                <i class="bi bi-search"></i>
                                <h5>Sonuç bulunamadı</h5>
                                <p class="text-muted">"${searchTerm}" için herhangi bir araç bulunamadı.</p>
                            </div>
                        </div>
                    `;
                    document.getElementById('vehiclesContainer').appendChild(noResults);
                }
            } else {
                const noResults = document.querySelector('.no-results');
                if (noResults) {
                    noResults.remove();
                }
            }
        });

        // Delete confirmation
        document.querySelectorAll('.delete-form').forEach(form => {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                if (confirm('Bu aracı silmek istediğinize emin misiniz? Bu işlem geri alınamaz.')) {
                    this.submit();
                }
            });
        });

        // Staff modal
        const staffModal = document.getElementById('staffModal');
        staffModal.addEventListener('show.bs.modal', function(event) {
            const button = event.relatedTarget;
            const plate = button.getAttribute('data-plate');
            const staffDataString = button.getAttribute('data-staff');
            const staffList = JSON.parse(staffDataString);

            const modalTitle = staffModal.querySelector('.modal-title');
            const modalBody = staffModal.querySelector('#staffModalBody');

            modalTitle.textContent = `${plate} Plakalı Araç Personeli`;
            modalBody.innerHTML = '';

            if (staffList && staffList.length > 0) {
                const listGroup = document.createElement('ul');
                listGroup.className = 'list-group';

                staffList.forEach(staff => {
                    const listItem = document.createElement('li');
                    listItem.className = 'list-group-item d-flex justify-content-between align-items-center';
                    listItem.innerHTML = `
                        <div>
                            <strong class="d-block">${staff.Name} ${staff.Surname}</strong>
                            <small class="text-muted">Telefon: ${staff.PhoneNumber ?? 'Belirtilmemiş'}</small>
                        </div>
                        <i class="bi bi-person-circle fs-4 text-secondary"></i>
                    `;
                    listGroup.appendChild(listItem);
                });
                modalBody.appendChild(listGroup);
            } else {
                modalBody.innerHTML = '<p class="text-center text-muted mt-3">Bu araca atanmış personel bulunmamaktadır.</p>';
            }
        });
    });
</script>