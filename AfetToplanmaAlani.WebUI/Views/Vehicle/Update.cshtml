@model AfetToplanmaAlani.EL.Models.Vehicle

@{
    ViewData["Title"] = "Araç Güncelle";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="form-card">
                <div class="form-header">
                    <h2><i class="bi bi-pencil-square me-2"></i>Araç Güncelle</h2>
                    <p>Araç bilgilerini güncelleyin</p>
                </div>

                <div class="form-body">
                    <form asp-action="Update" method="post" novalidate>
                        <input asp-for="Id" type="hidden" />

                        <!-- Plaka Türü -->
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="isWorkMachine">
                                <label class="form-check-label" for="isWorkMachine">
                                    <i class="bi bi-gear"></i> İş Makinesi
                                </label>
                            </div>
                        </div>

                        <!-- Plaka -->
                        <div class="mb-3">
                            <label asp-for="Plate" class="form-label fw-medium">Plaka <span class="text-danger">*</span></label>
                            <input asp-for="Plate" class="form-control" placeholder="Örnek: 34 A 1234" id="plateInput" />
                            <span asp-validation-for="Plate" class="text-danger"></span>
                            <div id="plateHint" class="text-muted mt-1">
                                <small><i class="bi bi-info-circle"></i> Normal araç formatı: 34 A 1234, 06 AB 123, 81 ABC 12</small>
                            </div>
                            <div id="plateError" class="text-danger" style="display: none;">
                                <i class="bi bi-exclamation-triangle"></i> Geçerli plaka formatı giriniz
                            </div>
                            <div id="plateSuccess" class="text-success" style="display: none;">
                                <i class="bi bi-check-circle"></i> Geçerli plaka formatı
                            </div>
                        </div>

                        <!-- Marka -->
                        <div class="mb-3">
                            <label asp-for="Brand" class="form-label fw-medium">Marka</label>
                            <input asp-for="Brand" class="form-control" placeholder="Örnek: Ford, Mercedes" />
                            <span asp-validation-for="Brand" class="text-danger"></span>
                        </div>

                        <!-- Model -->
                        <div class="mb-3">
                            <label asp-for="Model" class="form-label fw-medium">Model</label>
                            <input asp-for="Model" class="form-control" placeholder="Örnek: Transit, Sprinter" />
                            <span asp-validation-for="Model" class="text-danger"></span>
                        </div>

                        <!-- Tip -->
                        <div class="mb-3">
                            <label asp-for="Type" class="form-label fw-medium">Tip</label>
                            <input asp-for="Type" class="form-control" placeholder="Örnek: Kamyon, Minibüs" />
                            <span asp-validation-for="Type" class="text-danger"></span>
                        </div>

                        <!-- Renk -->
                        <div class="mb-3">
                            <label asp-for="Color" class="form-label fw-medium">Renk</label>
                            <input asp-for="Color" class="form-control" placeholder="Örnek: Beyaz, Kırmızı" />
                            <span asp-validation-for="Color" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-3 justify-content-center mt-4">
                            <button type="submit" class="btn-save">
                                <i class="bi bi-check-circle me-2"></i>Güncelle
                            </button>
                            <a asp-action="Index" class="btn-cancel">
                                <i class="bi bi-arrow-left-circle me-2"></i>Geri
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const plateInput = document.getElementById('plateInput');
        const plateError = document.getElementById('plateError');
        const plateSuccess = document.getElementById('plateSuccess');
        const plateHint = document.getElementById('plateHint');
        const isWorkMachineCheckbox = document.getElementById('isWorkMachine');

        const normalPlateRegex = /^[0-9]{2}\s[A-Z]{1,3}\s[0-9]{2,5}$/;
        const workMachineRegex = /^[0-9]{2}\s[0-9]{2}\s[0-9]{2}\s[0-9]{5}$/;

        const normalPlateFormats = {
            oneLetterFormat: /^[0-9]{2}\s[A-Z]{1}\s[0-9]{4,5}$/,
            twoLetterFormat: /^[0-9]{2}\s[A-Z]{2}\s[0-9]{3,4}$/,
            threeLetterFormat: /^[0-9]{2}\s[A-Z]{3}\s[0-9]{2,3}$/
        };

        // Detect current plate type on page load
        function detectCurrentPlateType() {
            const currentPlate = plateInput.value.trim();
            if (currentPlate && workMachineRegex.test(currentPlate)) {
                isWorkMachineCheckbox.checked = true;
            }
            updatePlateHint();
        }

        isWorkMachineCheckbox.addEventListener('change', function() {
            updatePlateHint();
            validatePlateInput();
        });

        function updatePlateHint() {
            if (isWorkMachineCheckbox.checked) {
                plateHint.innerHTML = '<small><i class="bi bi-info-circle"></i> İş makinesi formatı: 34 12 34 56789</small>';
                plateInput.placeholder = 'Örnek: 34 12 34 56789';
            } else {
                plateHint.innerHTML = '<small><i class="bi bi-info-circle"></i> Normal araç formatı: 34 A 1234, 06 AB 123, 81 ABC 12</small>';
                plateInput.placeholder = 'Örnek: 34 A 1234';
            }
        }

        function isValidProvinceCode(code) {
            const provinceCode = parseInt(code);
            return provinceCode >= 1 && provinceCode <= 81;
        }

        function validateNormalPlate(plate) {
            if (!normalPlateRegex.test(plate)) return false;
            const parts = plate.split(' ');
            if (parts.length !== 3) return false;
            if (!isValidProvinceCode(parts[0])) return false;
            switch (parts[1].length) {
                case 1: return normalPlateFormats.oneLetterFormat.test(plate);
                case 2: return normalPlateFormats.twoLetterFormat.test(plate);
                case 3: return normalPlateFormats.threeLetterFormat.test(plate);
                default: return false;
            }
        }

        function validateWorkMachinePlate(plate) {
            if (!workMachineRegex.test(plate)) return false;
            const parts = plate.split(' ');
            return parts.length === 4 && isValidProvinceCode(parts[0]);
        }

        function validatePlate(plate) {
            if (!plate || plate.trim() === '') return false;
            return isWorkMachineCheckbox.checked ? validateWorkMachinePlate(plate) : validateNormalPlate(plate);
        }

        function formatPlate(value) {
            value = value.toUpperCase().replace(/[^0-9A-Z\s]/g, '');
            const cleanValue = value.replace(/\s/g, '');
            return isWorkMachineCheckbox.checked ? formatWorkMachinePlate(cleanValue) : formatNormalPlate(cleanValue);
        }

        function formatNormalPlate(cleanValue) {
            let provinceCode = '', letterPart = '', numberPart = '', phase = 'province';
            for (let i = 0; i < cleanValue.length; i++) {
                const char = cleanValue[i];
                if (phase === 'province') {
                    if (/[0-9]/.test(char) && provinceCode.length < 2) {
                        if (provinceCode.length === 0 && char === '0') { provinceCode += char; }
                        else if (provinceCode.length === 0 && parseInt(char) >= 1 && parseInt(char) <= 8) { provinceCode += char; }
                        else if (provinceCode.length === 1) {
                            let potentialCode = parseInt(provinceCode + char);
                            if (potentialCode >= 1 && potentialCode <= 81) { provinceCode += char; phase = 'letter'; }
                        }
                    } else if (/[A-Z]/.test(char) && provinceCode.length >= 1) {
                        let currentCode = parseInt(provinceCode);
                        if ((provinceCode.length === 1 && currentCode >= 1 && currentCode <= 8) || (provinceCode.length === 2 && currentCode >= 1 && currentCode <= 81)) { phase = 'letter'; i--; }
                    }
                } else if (phase === 'letter') {
                    if (/[A-Z]/.test(char) && letterPart.length < 3) { letterPart += char; }
                    else if (/[0-9]/.test(char) && letterPart.length > 0) { phase = 'number'; i--; }
                } else if (phase === 'number') {
                    if (/[0-9]/.test(char)) {
                        let maxNumbers = letterPart.length === 2 ? 4 : (letterPart.length === 3 ? 3 : 5);
                        if (numberPart.length < maxNumbers) { numberPart += char; }
                    }
                }
            }
            let formatted = provinceCode;
            if (letterPart && provinceCode.length >= 1) { formatted += ' ' + letterPart; if (numberPart) { formatted += ' ' + numberPart; } }
            return formatted;
        }

        function formatWorkMachinePlate(cleanValue) {
            let provinceCode = '', group1 = '', group2 = '', serialNumber = '';
            for (let i = 0; i < cleanValue.length && i < 11; i++) {
                const char = cleanValue[i];
                if (/[0-9]/.test(char)) {
                    if (provinceCode.length < 2) {
                        if (provinceCode.length === 0 && (char === '0' || (parseInt(char) >= 1 && parseInt(char) <= 8))) { provinceCode += char; }
                        else if (provinceCode.length === 1) { let potentialCode = parseInt(provinceCode + char); if (potentialCode >= 1 && potentialCode <= 81) { provinceCode += char; } }
                    } else if (group1.length < 2) { group1 += char; }
                    else if (group2.length < 2) { group2 += char; }
                    else if (serialNumber.length < 5) { serialNumber += char; }
                }
            }
            let formatted = provinceCode;
            if (group1 && provinceCode.length >= 1) { formatted += ' ' + group1; if (group2) { formatted += ' ' + group2; if (serialNumber) { formatted += ' ' + serialNumber; } } }
            return formatted;
        }

        plateInput.addEventListener('input', function() {
            plateInput.value = formatPlate(plateInput.value);
            validatePlateInput();
        });

        function validatePlateInput() {
            const plateValue = plateInput.value.trim();
            if (plateValue === '') { hideValidationMessages(); return; }
            if (validatePlate(plateValue)) { showSuccess(); } else { showError(); }
        }

        function showError() { plateError.style.display = 'block'; plateSuccess.style.display = 'none'; plateInput.classList.add('is-invalid'); plateInput.classList.remove('is-valid'); }
        function showSuccess() { plateError.style.display = 'none'; plateSuccess.style.display = 'block'; plateInput.classList.add('is-valid'); plateInput.classList.remove('is-invalid'); }
        function hideValidationMessages() { plateError.style.display = 'none'; plateSuccess.style.display = 'none'; plateInput.classList.remove('is-invalid', 'is-valid'); }

        document.querySelector('form').addEventListener('submit', function(e) {
            const plateValue = plateInput.value.trim();
            if (plateValue && !validatePlate(plateValue)) { e.preventDefault(); showError(); plateInput.focus(); return false; }
        });

        // On page load, detect plate type and validate
        document.addEventListener('DOMContentLoaded', function() {
            detectCurrentPlateType();
            if (plateInput.value.trim()) { validatePlateInput(); }
        });
    </script>
}