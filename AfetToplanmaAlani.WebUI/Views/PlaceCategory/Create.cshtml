@model AfetToplanmaAlani.EL.Models.PlaceCategory
@{
    ViewData["Title"] = "Yeni Kategori Ekle";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="form-card">
                <div class="form-header">
                    <h2>
                        <i class="bi bi-plus-circle me-2"></i>
                        Yeni Kategori Ekle
                    </h2>
                    <p>Yer için yeni bir kategori oluşturun</p>
                </div>

                <div class="form-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-floating mb-4">
                            <input asp-for="Name" class="form-control" id="name"
                                   placeholder="Ör. Çadır Alanları vb." />
                            <label for="name">
                                <i class="bi bi-tag form-icon"></i>Kategori Adı
                            </label>
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-3 justify-content-center mt-4">
                            <button type="submit" class="btn-save">
                                <i class="bi bi-check-circle me-2"></i>Kaydet
                            </button>
                            <a asp-action="Index" class="btn-cancel">
                                <i class="bi bi-arrow-left me-2"></i>Geri Dön
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
