@model AfetToplanmaAlani.EL.Dtos.Staff.StaffDtoForCreate
@{
    ViewData["Title"] = "Yeni Personel Ekle";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="form-card">
                <div class="form-header">
                    <h2>
                        <i class="bi bi-person-plus-fill me-2"></i>
                        Yeni Personel Ekle
                    </h2>
                    <p>Sisteme yeni personel bilgilerini ekleyin</p>
                </div>

                <div class="form-body">
                    <form asp-action="Create" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-floating mb-3">
                            <input asp-for="Name" class="form-control" id="name" placeholder="Ad" />
                            <label for="name">
                                <i class="bi bi-person form-icon"></i>Ad
                            </label>
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Surname" class="form-control" id="surname" placeholder="Soyad" />
                            <label for="surname">
                                <i class="bi bi-person form-icon"></i>Soyad
                            </label>
                            <span asp-validation-for="Surname" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="PhoneNumber" class="form-control" id="phone" placeholder="Telefon Numarası" />
                            <label for="phone">
                                <i class="bi bi-telephone form-icon"></i>Telefon Numarası
                            </label>
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <select asp-for="PlaceId" asp-items="ViewBag.Places" class="form-select" id="place">
                                <option value="">-- Seçiniz --</option>
                            </select>
                            <label for="place">
                                <i class="bi bi-geo-alt form-icon"></i>Toplanma Noktası
                            </label>
                            <span asp-validation-for="PlaceId" class="text-danger"></span>
                        </div>

                        <div class="d-flex gap-3 justify-content-center mt-4">
                            <button type="submit" class="btn-save">
                                <i class="bi bi-check2-circle me-2"></i>Kaydet
                            </button>
                            <a asp-action="Index" class="btn-cancel">
                                <i class="bi bi-x-circle me-2"></i>İptal
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}