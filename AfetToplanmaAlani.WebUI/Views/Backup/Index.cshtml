@{
    ViewData["Title"] = "Yedekleme";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h1><i class="bi bi-shield-check me-2"></i>Yedekleme Merkezi</h1>
            <p>Veritabanını yedekleyin veya bir yedekten geri yükleyin</p>
        </div>
    </div>

    <!-- Alerts -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle me-2"></i>@TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Yedek Al Kartı -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header" style="background: var(--primary-gradient); color: white;">
                    <h5 class="mb-0"><i class="bi bi-download me-2"></i>Yedek Al</h5>
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="flex-grow-1">
                        <p class="text-muted mb-3">
                            Mevcut veritabanının bir kopyasını oluşturun. Yedek dosyası
                            <code>tarih-saat-afad.db</code> formatında kaydedilir.
                        </p>
                        <div class="alert alert-light border mb-3">
                            <h6 class="mb-2"><i class="bi bi-lightbulb me-1"></i>Yedek Neden Önemli?</h6>
                            <ul class="mb-0 small">
                                <li>Veri kaybına karşı koruma sağlar</li>
                                <li>Sistem güncellemelerinden önce alınmalıdır</li>
                                <li>Farklı bilgisayarlara aktarım yapabilirsiniz</li>
                            </ul>
                        </div>
                    </div>
                    <form asp-action="CreateBackup" method="post">
                        <button type="submit" class="btn-save w-100">
                            <i class="bi bi-cloud-arrow-down me-2"></i>Yedek Al
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Geri Yükle Kartı -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header" style="background: linear-gradient(135deg, #059669 0%, #10b981 100%); color: white;">
                    <h5 class="mb-0"><i class="bi bi-upload me-2"></i>Yedeği Geri Yükle</h5>
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="flex-grow-1">
                        <p class="text-muted mb-3">
                            Daha önce alınmış bir yedek dosyasından veritabanını geri yükleyin.
                        </p>
                        <div class="alert alert-warning border mb-3">
                            <h6 class="mb-2"><i class="bi bi-exclamation-triangle me-1"></i>Dikkat!</h6>
                            <ul class="mb-0 small">
                                <li>Geri yükleme mevcut verilerin üzerine yazılır</li>
                                <li>İşlem geri alınamaz</li>
                                <li>Önce mevcut durumun yedeğini almanız önerilir</li>
                            </ul>
                        </div>
                    </div>
                    
                    <!-- Electron modunda doğrudan buton, web modunda dosya seçici -->
                    <form asp-action="RestoreBackup" method="post" enctype="multipart/form-data" id="restoreForm">
                        <div class="mb-3" id="fileInputContainer">
                            <label for="backupFile" class="form-label">Yedek Dosyası Seç</label>
                            <input type="file" class="form-control" id="backupFile" name="backupFile" accept=".db">
                        </div>
                        <button type="submit" class="btn btn-success w-100 py-2">
                            <i class="bi bi-cloud-arrow-up me-2"></i>Yedeği Geri Yükle
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Bilgi Kartı -->
    <div class="card mt-4">
        <div class="card-body">
            <div class="row align-items-center">
                <div class="col-auto">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                        <i class="bi bi-database text-primary" style="font-size: 2rem;"></i>
                    </div>
                </div>
                <div class="col">
                    <h6 class="mb-1">Veritabanı Bilgisi</h6>
                    <p class="mb-0 text-muted small">
                        <strong>Dosya:</strong> app.db (SQLite) &nbsp;|&nbsp;
                        <strong>Konum:</strong> Uygulama dizini
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-save {
        background: var(--primary-gradient);
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: var(--radius-md);
        font-weight: 600;
        transition: all var(--transition-base);
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }
    
    .btn-save:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-lg);
        color: white;
    }
</style>
