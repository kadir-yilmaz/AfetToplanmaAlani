@model AfetToplanmaAlani.EL.Models.VehicleStaff

@{
    ViewData["Title"] = "Araç Personeli Güncelle";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <div class="form-card">
                <div class="form-header">
                    <h2><i class="bi bi-pencil-square me-2"></i>Araç Personeli Güncelle</h2>
                    <p>Mevcut personel bilgilerini güncelleyin</p>
                </div>

                <div class="form-body">
                    <form asp-action="Update" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Name" class="form-control" id="name" placeholder="Ad" />
                                    <label for="name"><i class="bi bi-person form-icon"></i>Ad <span class="text-danger">*</span></label>
                                </div>
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="Surname" class="form-control" id="surname" placeholder="Soyad" />
                                    <label for="surname"><i class="bi bi-person form-icon"></i>Soyad <span class="text-danger">*</span></label>
                                </div>
                                <span asp-validation-for="Surname" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input asp-for="PhoneNumber" class="form-control" id="phone" placeholder="Telefon" />
                                    <label for="phone"><i class="bi bi-telephone form-icon"></i>Telefon</label>
                                </div>
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <div class="form-floating">
                                    <select asp-for="VehicleId" class="form-select" id="vehicle">
                                        <option value="">Seçiniz...</option>
                                        @if (ViewBag.Vehicles != null)
                                        {
                                            foreach (var v in ViewBag.Vehicles)
                                            {
                                                <option value="@v.Id">@v.Plate - @v.Brand @v.Model</option>
                                            }
                                        }
                                    </select>
                                    <label for="vehicle"><i class="bi bi-truck form-icon"></i>Araç</label>
                                </div>
                                <span asp-validation-for="VehicleId" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-3 justify-content-center mt-4">
                            <button type="submit" class="btn-save">
                                <i class="bi bi-check-circle me-2"></i>Güncelle
                            </button>
                            <a asp-action="Index" class="btn-cancel">
                                <i class="bi bi-x-circle me-2"></i>İptal
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
