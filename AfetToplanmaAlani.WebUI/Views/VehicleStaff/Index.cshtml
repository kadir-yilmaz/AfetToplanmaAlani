@model X.PagedList.IPagedList<AfetToplanmaAlani.EL.Models.VehicleStaff>

@{
    ViewData["Title"] = "Araç Personeli Listesi";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1><i class="bi bi-person-vcard me-2"></i>Araç Personeli Listesi</h1>
            <p>Araçlara atanmış personelleri yönetin</p>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <!-- Search Form -->
            <form asp-action="Index" method="get" class="d-flex">
                <div class="input-group">
                    <input type="text" name="searchTerm" value="@ViewBag.SearchTerm"
                           class="form-control bg-white bg-opacity-20 border-white border-opacity-30 text-dark" 
                           placeholder="Ad, Soyad veya Plaka ara..."
                           style="min-width: 200px;" />
                    @if (!string.IsNullOrEmpty(ViewBag.SearchTerm as string))
                    {
                        <a asp-action="Index" class="btn btn-outline-light">
                            <i class="bi bi-x-circle"></i>
                        </a>
                    }
                </div>
            </form>

            <a asp-controller="Vehicle" asp-action="Index" class="btn-header-add" style="background: rgba(255,255,255,0.1);">
                <i class="bi bi-arrow-left me-2"></i>Araçlara Dön
            </a>
            <a asp-action="Create" class="btn-header-add">
                <i class="bi bi-person-plus-fill me-2"></i>Yeni Personel Ekle
            </a>
        </div>
    </div>

    <!-- Success Message -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Table -->
    <div class="table-card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Ad</th>
                            <th>Soyad</th>
                            <th>Telefon</th>
                            <th>Araç</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var staff in Model)
                            {
                                <tr>
                                    <td><strong>@staff.Name</strong></td>
                                    <td>@staff.Surname</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(staff.PhoneNumber))
                                        {
                                            <a href="tel:@staff.PhoneNumber" class="text-decoration-none">
                                                <i class="bi bi-telephone me-1"></i>@staff.PhoneNumber
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (staff.Vehicle != null)
                                        {
                                            <span class="badge bg-info">@staff.Vehicle.Plate</span>
                                            <span class="text-muted small">@staff.Vehicle.Brand @staff.Vehicle.Model</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Update" asp-route-id="@staff.Id" 
                                               class="btn-action btn-action-edit"
                                               title="Düzenle">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@staff.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn-action btn-action-delete"
                                                        onclick="return confirm('Bu personeli silmek istediğinize emin misiniz?');"
                                                        title="Sil">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5">
                                    <div class="empty-state">
                                        <i class="bi bi-person-vcard"></i>
                                        <h5>Henüz kayıtlı araç personeli yok</h5>
                                        <p class="text-muted">Personel eklemek için yukarıdaki butonu kullanın.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                <!-- Pagination -->
                @await Html.PartialAsync("_Pagination", Model)
            </div>
        </div>
    </div>
</div>