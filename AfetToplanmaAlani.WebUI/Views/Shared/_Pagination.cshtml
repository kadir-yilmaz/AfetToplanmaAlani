@model X.PagedList.IPagedList

@if (Model != null && Model.PageCount > 1)
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="text-muted small">
            Sayfa @Model.PageNumber / @Model.PageCount (Toplam @Model.TotalItemCount kayıt)
        </div>
        
        <div class="d-flex align-items-center">
            <label class="me-2 mb-0 small">Sayfa başına:</label>
            <select class="form-select form-select-sm" style="width: auto;" onchange="changePageSize(this.value)">
                <option value="20" selected="@(ViewBag.PageSize == 20)">20</option>
                <option value="50" selected="@(ViewBag.PageSize == 50)">50</option>
                <option value="100" selected="@(ViewBag.PageSize == 100)">100</option>
            </select>
        </div>
    </div>
    
    <nav aria-label="Sayfa navigasyonu">
        <ul class="pagination justify-content-center">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" 
                   href="@Url.Action(ViewContext.RouteData.Values["action"].ToString(), 
                                     new { pageNumber = Model.PageNumber - 1,
                                           pageSize = ViewBag.PageSize,
                                           search = ViewBag.Search, 
                                           workGroup = ViewBag.WorkGroup,
                                           place = ViewBag.Place,
                                           city = ViewBag.City,
                                           district = ViewBag.District,
                                           neighborhood = ViewBag.Neighborhood,
                                           searchTerm = ViewBag.SearchTerm,
                                           searchPlate = ViewBag.SearchPlate })"
                   aria-label="Önceki">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>

            @{
                var startPage = Math.Max(1, Model.PageNumber - 2);
                var endPage = Math.Min(Model.PageCount, Model.PageNumber + 2);
            }

            @if (startPage > 1)
            {
                <li class="page-item">
                    <a class="page-link" 
                       href="@Url.Action(ViewContext.RouteData.Values["action"].ToString(), 
                                         new { pageNumber = 1,
                                               pageSize = ViewBag.PageSize,
                                               search = ViewBag.Search, 
                                               workGroup = ViewBag.WorkGroup,
                                               place = ViewBag.Place,
                                               city = ViewBag.City,
                                               district = ViewBag.District,
                                               neighborhood = ViewBag.Neighborhood,
                                               searchTerm = ViewBag.SearchTerm,
                                               searchPlate = ViewBag.SearchPlate })">1</a>
                </li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                }
            }

            @for (var i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link" 
                       href="@Url.Action(ViewContext.RouteData.Values["action"].ToString(), 
                                         new { pageNumber = i,
                                               pageSize = ViewBag.PageSize,
                                               search = ViewBag.Search, 
                                               workGroup = ViewBag.WorkGroup,
                                               place = ViewBag.Place,
                                               city = ViewBag.City,
                                               district = ViewBag.District,
                                               neighborhood = ViewBag.Neighborhood,
                                               searchTerm = ViewBag.SearchTerm,
                                               searchPlate = ViewBag.SearchPlate })">@i</a>
                </li>
            }

            @if (endPage < Model.PageCount)
            {
                @if (endPage < Model.PageCount - 1)
                {
                    <li class="page-item disabled"><span class="page-link">...</span></li>
                }
                <li class="page-item">
                    <a class="page-link" 
                       href="@Url.Action(ViewContext.RouteData.Values["action"].ToString(), 
                                         new { pageNumber = Model.PageCount,
                                               pageSize = ViewBag.PageSize,
                                               search = ViewBag.Search, 
                                               workGroup = ViewBag.WorkGroup,
                                               place = ViewBag.Place,
                                               city = ViewBag.City,
                                               district = ViewBag.District,
                                               neighborhood = ViewBag.Neighborhood,
                                               searchTerm = ViewBag.SearchTerm,
                                               searchPlate = ViewBag.SearchPlate })">@Model.PageCount</a>
                </li>
            }

            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" 
                   href="@Url.Action(ViewContext.RouteData.Values["action"].ToString(), 
                                     new { pageNumber = Model.PageNumber + 1,
                                           pageSize = ViewBag.PageSize,
                                           search = ViewBag.Search, 
                                           workGroup = ViewBag.WorkGroup,
                                           place = ViewBag.Place,
                                           city = ViewBag.City,
                                           district = ViewBag.District,
                                           neighborhood = ViewBag.Neighborhood,
                                           searchTerm = ViewBag.SearchTerm,
                                           searchPlate = ViewBag.SearchPlate })"
                   aria-label="Sonraki">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
    
    <script>
        function changePageSize(newSize) {
            var currentUrl = new URL(window.location.href);
            currentUrl.searchParams.set('pageSize', newSize);
            currentUrl.searchParams.set('pageNumber', '1'); // Reset to first page
            window.location.href = currentUrl.toString();
        }
    </script>
}
else if (Model != null)
{
    <div class="text-center text-muted small mt-2">
        Toplam @Model.TotalItemCount kayıt
    </div>
}
